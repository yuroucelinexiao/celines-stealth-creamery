        <language>en-us</language><atom:link href="http://localhost:1313/celines-stealth-creamery/page/index.xml" rel="self" type="application/rss+xml" /><item>
            <title>Ratings Guide</title>
            <link>http://localhost:1313/celines-stealth-creamery/ratings-guide/</link>
            <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
            <guid>http://localhost:1313/celines-stealth-creamery/ratings-guide/</guid>
            <description>&lt;h2 id=&#34;taste&#34;&gt;Taste&#xD;&#xA;&lt;/h2&gt;&lt;p&gt;Pure vibes, the average rating across all taste-testers.&lt;/p&gt;&#xA;&lt;style&gt;&#xD;&#xA;    .no-border-table table, .no-border-table th, .no-border-table td { border: none !important; text-align: center !important; vertical-align: middle !important; }&#xD;&#xA;    .no-border-table table { margin: 0 auto; }&#xD;&#xA;    .no-border-table tr, .no-border-table tr:nth-child(even) { background-color: transparent !important; }&#xD;&#xA;    .no-border-table th { font-size: 1.25em !important; }&#xD;&#xA;    .half-star { position: relative; display: inline-block; }&#xD;&#xA;    .half-star::before { content: &#39;★&#39;; position: absolute; left: 0; width: 50%; overflow: hidden; }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;div class=&#34;no-border-table&#34; align=&#34;center&#34; style=&#34;margin: 0 auto;&#34;&gt;&#xD;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;&lt;strong&gt;Stars&lt;/strong&gt;&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;&lt;strong&gt;Description&lt;/strong&gt;&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★★★&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Heavenly decadence&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★★☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Very delicious, comparable to our favourite creameries&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Above average, yummy, could be slightly improved&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Below average, could be much improved&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★☆☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Unenjoyable, a struggle to finish&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;☆☆☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Inedible, straight to trash&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;h2 id=&#34;macros&#34;&gt;Macros&#xD;&#xA;&lt;/h2&gt;&lt;p&gt;Prioritizing pints that have high nutrient-to-calorie ratios (NCR) for satiety and macros.&lt;/p&gt;&#xA;&lt;div align=&#34;center&#34; style=&#34;margin: 3em auto;&#34;&gt;&#xD;&#xA;$$&#xD;&#xA;\text{NCR Score} = \frac{\text{Protein (g)} + \text{Fiber (g)}}{\text{Total Calories}} \times 100&#xD;&#xA;$$&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;no-border-table&#34; align=&#34;center&#34; style=&#34;margin: 0 auto;&#34;&gt;&#xD;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;&lt;strong&gt;Stars&lt;/strong&gt;&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;&lt;strong&gt;NCR Score&lt;/strong&gt;&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★★★&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&amp;gt;9&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★★☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;7–8.9&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;5–6.9&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;3–4.9&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★☆☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;1–2.9&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;☆☆☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&amp;lt;1&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;p&gt;Deductions:&lt;/p&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;minus &lt;span class=&#34;half-star&#34;&gt;☆&lt;/span&gt; for &amp;gt; 10g saturated fat&lt;/li&gt;&#xA;&lt;li&gt;minus &lt;span class=&#34;half-star&#34;&gt;☆&lt;/span&gt; for &amp;gt; 20g added sugars&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;h2 id=&#34;ease&#34;&gt;Ease&#xD;&#xA;&lt;/h2&gt;&lt;p&gt;The ease of preparation.&lt;/p&gt;&#xA;&lt;div class=&#34;no-border-table&#34; align=&#34;center&#34; style=&#34;margin: 0 auto;&#34;&gt;&#xD;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;&lt;strong&gt;Stars&lt;/strong&gt;&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;&lt;strong&gt;Ease&lt;/strong&gt;&lt;/th&gt;&#xA;          &lt;th&gt;&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★★★&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Spoon mixing only&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★★☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Blending all ingredients&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★★☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Hot water or microwave for steeping, dissolving, or melting&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★★☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Stovetop for cooking, thickening, or reducing&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;★☆☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Complex multi-stage preparation including overnight&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;span style=&#34;font-size: 1.5em;&#34;&gt;☆☆☆☆☆&lt;/span&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Specialized equipment or dangerous handling&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;/div&gt;</description>
        </item><item>
            <title>Recipes</title>
            <link>http://localhost:1313/celines-stealth-creamery/recipes/</link>
            <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
            <guid>http://localhost:1313/celines-stealth-creamery/recipes/</guid>
            <description>&lt;p&gt;The best iteration of each flavour:&lt;/p&gt;&#xA;&lt;style&gt;&#xD;&#xA;    .recipe-grid {&#xD;&#xA;        display: grid;&#xD;&#xA;        grid-template-columns: repeat(3, 1fr);&#xD;&#xA;        gap: 1.5rem;&#xD;&#xA;        list-style: none;&#xD;&#xA;        padding: 0;&#xD;&#xA;        margin-bottom: 2rem;&#xD;&#xA;    }&#xD;&#xA;    .recipe-card {&#xD;&#xA;        display: flex;&#xD;&#xA;        flex-direction: column;&#xD;&#xA;    }&#xD;&#xA;    @media (max-width: 768px) {&#xD;&#xA;        .recipe-grid {&#xD;&#xA;            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;div class=&#34;recipes-by-category&#34;&gt;&#xD;&#xA;    &#xD;&#xA;        &lt;h3&gt;Fruity&lt;/h3&gt;&#xD;&#xA;        &lt;ul class=&#34;recipe-grid&#34;&gt;&#xD;&#xA;            &#xD;&#xA;                &#xD;&#xA;                    &lt;li class=&#34;recipe-card&#34;&gt;&#xD;&#xA;                        &lt;a href=&#34;http://localhost:1313/celines-stealth-creamery/p/f1-1-pina-colada/&#34; style=&#34;display: block; margin-bottom: 0.5rem; text-align: center; font-weight: bold;&#34;&gt;F1.1 Pina Colada&lt;/a&gt;&#xD;&#xA;                        &#xD;&#xA;                            &lt;a href=&#34;http://localhost:1313/celines-stealth-creamery/p/f1-1-pina-colada/&#34; style=&#34;display: block;&#34;&gt;&#xD;&#xA;                                &#xD;&#xA;                                &#xD;&#xA;                                    &lt;img src=&#34;http://localhost:1313/celines-stealth-creamery/p/f1-1-pina-colada/f1_1.png&#34; alt=&#34;F1.1 Pina Colada&#34; style=&#34;width: 100%; border-radius: 8px; object-fit: cover; aspect-ratio: 16/9;&#34; /&gt;&#xD;&#xA;                                &#xD;&#xA;                            &lt;/a&gt;&#xD;&#xA;                        &#xD;&#xA;                    &lt;/li&gt;&#xD;&#xA;                &#xD;&#xA;            &#xD;&#xA;        &lt;/ul&gt;&#xD;&#xA;    &#xD;&#xA;        &lt;h3&gt;Protein&lt;/h3&gt;&#xD;&#xA;        &lt;ul class=&#34;recipe-grid&#34;&gt;&#xD;&#xA;            &#xD;&#xA;                &#xD;&#xA;                    &lt;li class=&#34;recipe-card&#34;&gt;&#xD;&#xA;                        &lt;a href=&#34;http://localhost:1313/celines-stealth-creamery/p/p1-1-chocolate-and-nuts/&#34; style=&#34;display: block; margin-bottom: 0.5rem; text-align: center; font-weight: bold;&#34;&gt;P1.1 Chocolate &amp;amp; Nuts&lt;/a&gt;&#xD;&#xA;                        &#xD;&#xA;                            &lt;a href=&#34;http://localhost:1313/celines-stealth-creamery/p/p1-1-chocolate-and-nuts/&#34; style=&#34;display: block;&#34;&gt;&#xD;&#xA;                                &#xD;&#xA;                                &#xD;&#xA;                                    &lt;img src=&#34;http://localhost:1313/celines-stealth-creamery/p/p1-1-chocolate-and-nuts/p1_1.png&#34; alt=&#34;P1.1 Chocolate &amp;amp; Nuts&#34; style=&#34;width: 100%; border-radius: 8px; object-fit: cover; aspect-ratio: 16/9;&#34; /&gt;&#xD;&#xA;                                &#xD;&#xA;                            &lt;/a&gt;&#xD;&#xA;                        &#xD;&#xA;                    &lt;/li&gt;&#xD;&#xA;                &#xD;&#xA;            &#xD;&#xA;        &lt;/ul&gt;&#xD;&#xA;    &#xD;&#xA;&lt;/div&gt;&#xA;</description>
